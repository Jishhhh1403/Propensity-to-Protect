# Google Cloud context
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# GCS raw input
GCS_BUCKET=propensitysyntheticdata
GCS_PREFIX=

# BigQuery destination
# Set to false on Vertex / prod if the runtime SA lacks bigquery.tables.delete (default true when unset = local drop+recreate).
PIPELINE_RECREATE_BQ_TABLES=true
BQ_DATASET=insurance_features
BQ_DAILY_FEATURES_TABLE=daily_features
BQ_POLICY_EVENTS_TABLE=policy_events
# 30-day sequences input table used by the GRU training pipeline
BQ_POLICY_SEQUENCES_TABLE=policy_2024_2025_30_day_sequences
# GRU output table: one row per policy purchase event with embedding + probabilities
BQ_PROPENSITY_EMBEDDINGS_TABLE=policy_propensity_gru_embeddings

# Model artifacts (SavedModel + scaler + mappings) written to GCS
MODEL_ARTIFACTS_GCS_PREFIX=

# Vertex AI runtime (optional but recommended)
VERTEX_IMAGE_URI=us-central1-docker.pkg.dev/project-4f5c01e7-972b-4b20-afc/cloud-propensity/cloud-propensity:latest
VERTEX_SERVICE_ACCOUNT=
# Must be a bucket in the same *region* as GCP_REGION (not multi-region US). Default if unset: gs://<GCP_PROJECT_ID>-vertex-ai-staging
VERTEX_STAGING_BUCKET=
VERTEX_PIPELINE_ROOT=
